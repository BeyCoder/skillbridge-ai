{
  "manifest_version": 3,
  "name": "SkillBridge AI",
  "description": "Translates job postings into truthful, tailored resumes, cover letters, and application stories with Codex.",
  "version": "2.1.59",
  "permissions": ["activeTab", "scripting", "storage", "debugger"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SkillBridge AI",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["defaults.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
